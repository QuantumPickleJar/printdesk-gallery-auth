PORT=5175
HOST=0.0.0.0
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ALLOWED_GITHUB_USER=QuantumPickleJar
TARGET_OWNER=QuantumPickleJar
TARGET_REPO=Personal-Static
TARGET_BRANCH=main
GALLERY_JSON_PATH=data/3d-print-gallery.json
GALLERY_ASSET_BASE_PATH=assets/gallery
GALLERY_ATTACHMENT_BASE_PATH=assets/gallery-attachments
SESSION_COOKIE_NAME=pg_admin_sid

# Optional local/demo owner unlock fallback.
# Prefer LOCAL_OWNER_UNLOCK_SHA256 if you do not want the raw password in the Pi .env.
LOCAL_OWNER_UNLOCK=
LOCAL_OWNER_UNLOCK_SHA256=
LOCAL_OWNER_SESSION_MINUTES=240

# Credentialed CORS origins allowed to call local-owner endpoints from PrintDesk.
# Tailnet HTTPS example: https://<desktop-full-tailnet-name>
LOCAL_OWNER_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://<desktop-full-tailnet-name>

# Tailnet HTTPS via Tailscale Serve should use SameSite=None and Secure=true.
# Non-HTTPS local testing can use Lax / false.
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=true
